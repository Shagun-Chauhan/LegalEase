# Copy this file to `.env` in the same folder (backend/) and fill in values.
# Never commit `.env` with real secrets.

# Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# MongoDB Atlas → Connect → Drivers → full connection string (replace password)
# Example: mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/legalease?retryWrites=true&w=majority
MONGODB_URI=

PORT=5001

# Optional — use a compatible, widely-available Gemini model alias
GEMINI_MODEL=gemini-1.5-flash-latest
